# ─────────────────────────────────────────────
# CTIS OKX — Environment Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── Django ────────────────────────────────────
DJANGO_SECRET_KEY=change-me-use-a-very-long-random-string-here
DJANGO_DEBUG=False
# Add your server's local IP (run: ip a | grep 192.168)
# Example: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────
POSTGRES_DB=ctis_okx
POSTGRES_USER=ctis
POSTGRES_PASSWORD=ctis_secret_change_me

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Server ────────────────────────────────────
# Port exposed on the host (access via http://<server-ip>:HTTP_PORT)
HTTP_PORT=80

# ── OKX API ───────────────────────────────────
# Data pública (market data) no requiere API key
# Si quieres operar o usar datos privados, obtén las claves en:
# https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_SIMULATED=False

# ── Telegram Bot ──────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot → copia el token
# 2. Abre https://api.telegram.org/bot<TOKEN>/getUpdates → busca "chat.id"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scanner Configuration ─────────────────────
# Top N activos por volumen 24h (mínimo recomendado: 50)
TOP_SYMBOLS_COUNT=50
# Intervalo del scanner automático en segundos (900 = 15 min)
SCANNER_INTERVAL=900
# Multiplicador mínimo de volumen para anomalía
VOLUME_THRESHOLD=2.0
# % mínimo de ruptura sobre el nivel
BREAKOUT_THRESHOLD_PCT=0.002
# Señales máximas por activo en la ventana de dedup
MAX_SIGNALS_PER_ASSET=3
QUOTE_CURRENCY=USDT
